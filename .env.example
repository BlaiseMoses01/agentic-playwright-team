TARGET=https://your-app-url.com
GITHUB_API_TOKEN=your-github-token
GITHUB_REPO=your-repo-name
GITHUB_OWNER=your-github-username

# Test users — one set of vars per role
# Format: TEST_USER_<ROLE>_EMAIL, TEST_USER_<ROLE>_PASSWORD, TEST_USER_<ROLE>_NAME
TEST_USER_ADMIN_EMAIL=admin@example.com
TEST_USER_ADMIN_PASSWORD=changeme
TEST_USER_ADMIN_NAME=Admin User

TEST_USER_STANDARD_EMAIL=user@example.com
TEST_USER_STANDARD_PASSWORD=changeme
TEST_USER_STANDARD_NAME=Standard User
